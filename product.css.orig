@font-face {
    font-family: Helvet;
    src: url(fonts/FreeSans.otf);

    font-family: Gilroy;
    src: url(fonts/Gilroy-ExtraBold.otf);

    font-family: Rationell;
    src: url(fonts/Fontspring-DEMO-rationell-regular.otf);

    font-family: Rhizome;
    src: url(fonts/Rhizome-RegularTrial.otf);
}
html {
  background-image: url(assets/Pattern.jpg);
  scroll-behavior: smooth;
}
*{
margin: 0;
  text-decoration: none;
}

nav {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #222222;
    color: white;
    font-size: 18px;
    padding-left: 55px;
    /* padding: 10px; */
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
  }

  nav a {
    
    color: white;
    text-decoration: none;
    padding-top: 15px;
    padding-bottom: 15px;
    padding-left: 20px;
    padding-right: 20px;
    /* margin-right: 40px; */
    font-family: Rhizome;
    

  }

  nav a:hover {
    color: #0c0c0c;
    background-color:#dab71f;
    border-radius: 50px;
    -webkit-transition: width 0.8s ease;
    transition: background-color 0.8s ease;
  }

  .navbar {
    margin-right: 60px;
    padding-top: 10px;
    padding-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex: 1;
  }

  .logo {
    display: inline-block;
    justify-content: flex-start;
    z-index: 2;
    padding-right: 50%;
    padding-top: 0%;
    padding-bottom: 0%;
    flex: 3;
   
  }
  .LogoMain {
    object-fit: contain;
    width: 80px;
    height: 80px;
   
  }
  .LogoMain:hover {
    background-color:#dab71f;
    cursor: pointer;
   
  }

  .menu-icon {
    display: none; /* Hide the menu icon */
  }
 .category-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 13%;
 }
 .nav-btn {
   background-color: white;
   border: 1px solid #222222;
   padding: 10px 20px;
   font-size: 16px;
   font-weight: bold;
   text-align: center;
   text-transform: uppercase;
   color: #222222;
   cursor: pointer;
   margin-right: 10px;
   border-radius: 5px;
   font-family: Gilroy;
   -webkit-transition: width 0.4s ease-in-out;
   transition: all 0.4s ease-in-out;

 }

 .nav-btn.active {
   background-color: #222222;
   color: white;
 }
 .nav-btn:hover{
   background-color: #222222;
   color: white;
   transform: scale(1.2);
 }


  /* Style for the main content */
  .maincontainer1{
    display: flex;
    width: 1250px;
    height: 700px;
    background-color: rgb(247, 247, 247);
    margin-top: 8%;
    padding-bottom: 75%;
    padding-left: 20px;
    padding-right: 20px;
    padding-top: 20px;
    margin-left: 2%;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.125);
    border-radius: 6px;
    opacity: .94;
  }

  h1
  .container1, .container2 {
    width: 48%; /* adjust this value to change the width of the boxes */
    height: 100px; /* adjust this value to change the height of the boxes */
    background-color: transparent; /* adjust this value to change the background color of the boxes */
    max-width: 800px;
    margin: 80px auto 40px;
    padding-bottom: 40%;
    /* padding: 20px; */
    /* text-align: center; */
    
    /* box-shadow: 0 0 10px rgba(0, 0, 0, 0.1); */
    border-radius: 5px;
  }


  h1 {
    font-size: clamp(1.5625rem, 0.7031rem + 2.75vw, 2.25rem);
    /* margin-bottom: 20px; */
    color: #333;
    /* margin-top: 23%; */
  }

  p {
    font-size: clamp(1rem, 0.9219rem + 0.25vw, 1.125rem);
    line-height: 1.5;
    margin-bottom: 20px;
    color: #333;
    max-width: 100%;
  }

  h1, p, .textinfo {
    /* margin-top: 15%; */
    padding-left: 8%;
    padding-right: 20px;
    /* padding-top: 20px; */
    font-family: Gilroy;
    
  }

  .btn-l {
    background-color: #222222;
    color: white;
    padding: 12px 20px;
    box-sizing: border-box;
    border: 2px solid #222222;
    border-radius: 4px;
    cursor: pointer;
    -webkit-transition: width 0.4s ease;
  transition: background-color 0.4s ease;
}
.btn-r {
  background-color: #222222;
  color: white;
  padding-top: 10px;
  padding-bottom: 10px;
  padding-left: 20px;
  padding-right: 20px;

  box-sizing: border-box;
  border: 2px solid #222222;
  border-radius: 4px;
  cursor: pointer;
  -webkit-transition: width 0.4s ease;
transition: background-color 0.4s ease;
}
.btn-M {
  margin-left: 1%;
  margin-top: 2%;
    background-color: white ;
    color: #222222;
    padding: 1vw 1vw;
    flex: 2;
    box-sizing: border-box;
    border: 2px solid #222222;
    border-radius: 4px;
    cursor: pointer;
    display: inline;
    -webkit-transition: width 0.4s ease;
  transition: background-color 0.4s ease;
}
